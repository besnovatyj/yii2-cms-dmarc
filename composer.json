{
  "name": "besnovatyj/yii2-cms-dmarc",
  "description": "Модуль просмотра DMARC aggregate-отчётов для Yii2 CMS",
  "type": "yii2-extension",
  "license": "MIT",
  "authors": [
    {
      "name": "Besnovatyj",
      "email": "your-email@example.com"
    }
  ],
  "minimum-stability": "stable",
  "extra": {
    "moduleClass": "Besnovatyj\\Dmarc\\Module",
    "moduleId": "Dmarc",
    "bescms": { "kind": "module" },
    "config-plugin": {
      "common": "src/config/common.php"
    }
  },
  "keywords": [
    "yii2",
    "dmarc",
    "email",
    "security",
    "cms"
  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    },
    "fxp-asset": {
      "enabled": false
    }
  },
  "require": {
    "besnovatyj/yii2-cms-kernel": "^1.0",
    "besnovatyj/yii2-cms-contracts": "^1.0",
    "php": ">=8.4",
    "ext-simplexml": "*",
    "ext-libxml": "*",
    "ext-zip": "*",
    "ext-zlib": "*",
    "yiisoft/yii2": "~2.0.0",
    "yiisoft/yii2-bootstrap5": "~2.0.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Besnovatyj\\Dmarc\\": "src/"
    }
  }
}
